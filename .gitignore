# ====================================================================
# WORDPRESS CORE
# ====================================================================
# Ignore the entire standard WordPress core file matrix.
# These are managed by the WP updater; tracking them causes massive noise.
/wp-admin/
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-activate.php
/wp-blog-header.php
/wp-comments-post.php
/wp-cron.php
/wp-links-opml.php
/wp-load.php
/wp-login.php
/wp-mail.php
/wp-settings.php
/wp-signup.php
/wp-trackback.php
xmlrpc.php

# ====================================================================
# CONFIGURATION & SENSITIVE FILES (CRITICAL)
# ====================================================================
wp-config.php
!.gitignore

# ====================================================================
# WP-CONTENT DIRECTORY
# ====================================================================
# Ignore user-generated media library content and system artifacts
/wp-content/uploads/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backups-dup-lite/
/wp-content/debug.log

# Ignore all plugins and themes globally from tracking
/wp-content/plugins/
/wp-content/themes/

# ====================================================================
# PLUGINS & THEMES (STRATEGY)
# ====================================================================
# We are intentionally tracking all plugins and themes ("Monolithic" strategy)
# to guarantee that Staging and Production servers never diverge.

# ====================================================================
# DEVELOPMENT UTILITIES & BACKUPS
# ====================================================================
*.zip
*.tar.gz
*.sql
*.log
.DS_Store
.idea/
.vscode/
# Ignore boilerplate and text dump artifacts
wp-config-sample.php
tec_settings_backup.txt

# Ignore specific plugin backup dumps
/wp-content/ai1wm-backups/
/wp-content/plugins/all-in-one-wp-migration/storage/
/wp-content/updraft/
.htaccess
