{"translation-revision-date":"2026-04-15 10:31+0000","generator":"WP-CLI\/2.11.0","source":"src\/SettingsLoad.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"ar","plural-forms":"nplurals=6; plural=(n==0 ? 0 : n==1 ? 1 : n==2 ? 2 : n%100>=3 && n%100<=10 ? 3 : n%100>=11 ? 4 : 5);"},"Auto Login":["\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a"],"No More Manual Login":["\u0644\u0627 \u0645\u0632\u064a\u062f \u0645\u0646 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u064a\u062f\u0648\u064a"],"Login Redirects":["\u0625\u0639\u0627\u062f\u0629 \u062a\u0648\u062c\u064a\u0647 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"Automatically redirects the login":["\u064a\u0639\u064a\u062f \u062a\u0648\u062c\u064a\u0647 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u062a\u0644\u0642\u0627\u0626\u064a\u064b\u0627"],"Limit Login Attempts":["\u062a\u062d\u062f\u064a\u062f \u0645\u062d\u0627\u0648\u0644\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"Limits for login attempts":["\u0627\u0644\u062d\u062f\u0648\u062f \u0644\u0645\u062d\u0627\u0648\u0644\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"Hide Login":["\u0625\u062e\u0641\u0627\u0621 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"Hide your login page":["\u0625\u062e\u0641\u0627\u0621 \u0635\u0641\u062d\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0643"],"Social Login":["\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a"],"Third Party login access":["\u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0645\u0646 \u062c\u0647\u0629 \u062e\u0627\u0631\u062c\u064a\u0629"],"UPGRADE NOW":["\u062a\u0631\u0642\u064a\u0629 \u0627\u0644\u0622\u0646"],"Captchas":["\u0643\u0627\u0628\u062a\u0634\u0627\u062a"],"CAPTCHA Protection Settings":["\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u062d\u0645\u0627\u064a\u0629 \u0643\u0627\u0628\u062a\u0634\u0627"],"Integrations":["\u0627\u0644\u062a\u0643\u0627\u0645\u0644\u0627\u062a"],"This LoginPress add-on lets you change the login page URL to anything you want. It will give a hard time to spammers who keep hitting to your login page. This is helpful for Brute force attacks. One caution to use this add-on is you need to remember the custom login url after you change it. We have an option to email your custom login url so you remember it.":["\u062a\u062a\u064a\u062d \u0644\u0643 \u0647\u0630\u0647 \u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u0645\u0646 LoginPress \u062a\u063a\u064a\u064a\u0631 \u0639\u0646\u0648\u0627\u0646 URL \u0644\u0635\u0641\u062d\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0625\u0644\u0649 \u0623\u064a \u0634\u064a\u0621 \u062a\u0631\u064a\u062f\u0647. \u0633\u064a\u0648\u0641\u0631 \u0648\u0642\u062a\u064b\u0627 \u0639\u0635\u064a\u0628\u064b\u0627 \u0644\u0644\u0633\u0628\u0627\u0645\u0631\u0632 \u0627\u0644\u0630\u064a\u0646 \u064a\u0633\u062a\u0645\u0631\u0648\u0646 \u0641\u064a \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0635\u0641\u062d\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0643. \u0647\u0630\u0627 \u0645\u0641\u064a\u062f \u0644\u0647\u062c\u0645\u0627\u062a \u0627\u0644\u0642\u0648\u0629 \u0627\u0644\u063a\u0627\u0634\u0645\u0629. \u062a\u062d\u0630\u064a\u0631 \u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0647\u0630\u0647 \u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u0647\u0648 \u0623\u0646\u0643 \u062a\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u062a\u0630\u0643\u0631 \u0639\u0646\u0648\u0627\u0646 URL \u0627\u0644\u0645\u062e\u0635\u0635 \u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0628\u0639\u062f \u062a\u063a\u064a\u064a\u0631\u0647. \u0644\u062f\u064a\u0646\u0627 \u062e\u064a\u0627\u0631 \u0644\u0625\u0631\u0633\u0627\u0644 \u0639\u0646\u0648\u0627\u0646 URL \u0627\u0644\u0645\u062e\u0635\u0635 \u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u062d\u062a\u0649 \u062a\u062a\u0630\u0643\u0631\u0647."],"Everybody needs a control of their Login page. This will help you to track your login attempts by each user. You can limit the login attempts for each user. Brute force attacks are the most common way to gain access to your website. This add-on acts as a sheild to these hacking attacks and gives you control to set the time between each login attempts.":["\u064a\u062d\u062a\u0627\u062c \u0627\u0644\u062c\u0645\u064a\u0639 \u0625\u0644\u0649 \u0627\u0644\u0633\u064a\u0637\u0631\u0629 \u0639\u0644\u0649 \u0635\u0641\u062d\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0647\u0645. \u0633\u064a\u0633\u0627\u0639\u062f\u0643 \u0630\u0644\u0643 \u0639\u0644\u0649 \u062a\u062a\u0628\u0639 \u0645\u062d\u0627\u0648\u0644\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0644\u0643\u0644 \u0645\u0633\u062a\u062e\u062f\u0645. \u064a\u0645\u0643\u0646\u0643 \u062a\u062d\u062f\u064a\u062f \u0639\u062f\u062f \u0645\u062d\u0627\u0648\u0644\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0644\u0643\u0644 \u0645\u0633\u062a\u062e\u062f\u0645. \u062a\u0639\u062a\u0628\u0631 \u0647\u062c\u0645\u0627\u062a \u0627\u0644\u0642\u0648\u0629 \u0627\u0644\u063a\u0627\u0634\u0645\u0629 \u0647\u064a \u0627\u0644\u0637\u0631\u064a\u0642\u0629 \u0627\u0644\u0623\u0643\u062b\u0631 \u0634\u064a\u0648\u0639\u064b\u0627 \u0644\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0645\u0648\u0642\u0639\u0643. \u062a\u0639\u0645\u0644 \u0647\u0630\u0647 \u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u0643\u062f\u0631\u0639 \u0636\u062f \u0647\u0630\u0647 \u0627\u0644\u0647\u062c\u0645\u0627\u062a \u0627\u0644\u0642\u0631\u0635\u0646\u0629 \u0648\u062a\u0645\u0646\u062d\u0643 \u0627\u0644\u0633\u064a\u0637\u0631\u0629 \u0639\u0644\u0649 \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0648\u0642\u062a \u0628\u064a\u0646 \u0643\u0644 \u0645\u062d\u0627\u0648\u0644\u0629 \u062a\u0633\u062c\u064a\u0644 \u062f\u062e\u0648\u0644."],"Social login from LoginPress is an add-on which provides facility your users to login and Register via Facebook, Google and Twitter. This add-on will eliminate the Spam and Bot registrations. This add-on will help your users to hassle free registrations\/logins on your site.":["\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a \u0645\u0646 LoginPress \u0647\u0648 \u0625\u0636\u0627\u0641\u0629 \u062a\u0648\u0641\u0631 \u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0643 \u0625\u0645\u0643\u0627\u0646\u064a\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0648\u0627\u0644\u062a\u0633\u062c\u064a\u0644 \u0639\u0628\u0631 \u0641\u064a\u0633\u0628\u0648\u0643 \u0648\u062c\u0648\u062c\u0644 \u0648\u062a\u0648\u064a\u062a\u0631. \u0633\u062a\u0642\u0636\u064a \u0647\u0630\u0647 \u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u0639\u0644\u0649 \u0627\u0644\u062a\u0633\u062c\u064a\u0644\u0627\u062a \u063a\u064a\u0631 \u0627\u0644\u0645\u0631\u063a\u0648\u0628 \u0641\u064a\u0647\u0627 \u0648\u0627\u0644\u062a\u0633\u062c\u064a\u0644\u0627\u062a \u0627\u0644\u0622\u0644\u064a\u0629. \u0633\u062a\u0633\u0627\u0639\u062f \u0647\u0630\u0647 \u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0643 \u0639\u0644\u0649 \u0627\u0644\u062a\u0633\u062c\u064a\u0644\u0627\u062a\/\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0628\u062f\u0648\u0646 \u0645\u062a\u0627\u0639\u0628 \u0641\u064a \u0645\u0648\u0642\u0639\u0643."],"Redirect users based on their roles and specific usernames. This is helpful, If you have an editor and want to redirect him to his editor stats page. Restrict your subscribers, guests or even customers to certain pages instead of wp-admin. This add-on has a cool UX\/UI to manage all the login redirects you have created on your site.":["\u0625\u0639\u0627\u062f\u0629 \u062a\u0648\u062c\u064a\u0647 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0623\u062f\u0648\u0627\u0631\u0647\u0645 \u0648\u0623\u0633\u0645\u0627\u0621 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0627\u0644\u0645\u062d\u062f\u062f\u0629. \u0647\u0630\u0627 \u0645\u0641\u064a\u062f\u060c \u0625\u0630\u0627 \u0643\u0627\u0646 \u0644\u062f\u064a\u0643 \u0645\u062d\u0631\u0631 \u0648\u062a\u0631\u063a\u0628 \u0641\u064a \u0625\u0639\u0627\u062f\u0629 \u062a\u0648\u062c\u064a\u0647\u0647 \u0625\u0644\u0649 \u0635\u0641\u062d\u0629 \u0625\u062d\u0635\u0627\u0626\u064a\u0627\u062a \u0627\u0644\u0645\u062d\u0631\u0631 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0647. \u0642\u0645 \u0628\u062a\u0642\u064a\u064a\u062f \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u064a\u0646 \u0644\u062f\u064a\u0643\u060c \u0648\u0627\u0644\u0636\u064a\u0648\u0641 \u0623\u0648 \u062d\u062a\u0649 \u0627\u0644\u0639\u0645\u0644\u0627\u0621 \u0625\u0644\u0649 \u0635\u0641\u062d\u0627\u062a \u0645\u0639\u064a\u0646\u0629 \u0628\u062f\u0644\u0627\u064b \u0645\u0646 wp-admin. \u0647\u0630\u0647 \u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u062a\u062c\u0631\u0628\u0629 \u0645\u0633\u062a\u062e\u062f\u0645\/\u0648\u0627\u062c\u0647\u0629 \u0645\u0633\u062a\u062e\u062f\u0645 \u0631\u0627\u0626\u0639\u0629 \u0644\u0625\u062f\u0627\u0631\u0629 \u062c\u0645\u064a\u0639 \u0625\u0639\u0627\u062f\u0629 \u062a\u0648\u062c\u064a\u0647\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062a\u064a \u0642\u0645\u062a \u0628\u0625\u0646\u0634\u0627\u0626\u0647\u0627 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639\u0643."],"This LoginPress add-on lets you (Adminstrator) generates a unique URL for your certain users who you don't want to provide a password to login into your site. This Pro add-on gives you a list of all the users who you have given auto generated login links. You can disable someones access and delete certain users.":["\u062a\u062a\u064a\u062d \u0644\u0643 \u0625\u0636\u0627\u0641\u0629 LoginPress (\u0627\u0644\u0645\u0633\u0624\u0648\u0644) \u0625\u0646\u0634\u0627\u0621 \u0639\u0646\u0648\u0627\u0646 URL \u0641\u0631\u064a\u062f \u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0645\u0639\u064a\u0646\u064a\u0646 \u0644\u0627 \u062a\u0631\u063a\u0628 \u0641\u064a \u062a\u0642\u062f\u064a\u0645 \u0643\u0644\u0645\u0629 \u0645\u0631\u0648\u0631 \u0644\u0647\u0645 \u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0625\u0644\u0649 \u0645\u0648\u0642\u0639\u0643. \u062a\u0645\u0646\u062d\u0643 \u0647\u0630\u0647 \u0627\u0644\u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0627\u062d\u062a\u0631\u0627\u0641\u064a\u0629 \u0642\u0627\u0626\u0645\u0629 \u0628\u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0642\u062f\u0645\u062a \u0644\u0647\u0645 \u0631\u0648\u0627\u0628\u0637 \u062a\u0633\u062c\u064a\u0644 \u062f\u062e\u0648\u0644 \u062a\u0645 \u0625\u0646\u0634\u0627\u0624\u0647\u0627 \u062a\u0644\u0642\u0627\u0626\u064a\u064b\u0627. \u064a\u0645\u0643\u0646\u0643 \u062a\u0639\u0637\u064a\u0644 \u0648\u0635\u0648\u0644 \u0628\u0639\u0636 \u0627\u0644\u0623\u0634\u062e\u0627\u0635 \u0648\u062d\u0630\u0641 \u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0645\u0639\u064a\u0646\u064a\u0646."],"The LoginPress CAPTCHA feature lets you easily integrate different types of CAPTCHA services into your login and registration forms. CAPTCHA types offered include Google reCAPTCHA, hCAPTCHA, and other widely used CAPTCHA services. This feature helps prevent spam, bot attacks, and authorized access, ensuring a more secure user experience.":["\u062a\u062a\u064a\u062d \u0644\u0643 \u0645\u064a\u0632\u0629 CAPTCHA \u0641\u064a LoginPress \u062f\u0645\u062c \u0623\u0646\u0648\u0627\u0639 \u0645\u062e\u062a\u0644\u0641\u0629 \u0645\u0646 \u062e\u062f\u0645\u0627\u062a CAPTCHA \u0628\u0633\u0647\u0648\u0644\u0629 \u0641\u064a \u0646\u0645\u0627\u0630\u062c \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0648\u0627\u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0643. \u062a\u0634\u0645\u0644 \u0623\u0646\u0648\u0627\u0639 CAPTCHA \u0627\u0644\u0645\u0639\u0631\u0648\u0636\u0629 Google reCAPTCHA \u0648 hCAPTCHA \u0648\u063a\u064a\u0631\u0647\u0627 \u0645\u0646 \u062e\u062f\u0645\u0627\u062a CAPTCHA \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u0629 \u0639\u0644\u0649 \u0646\u0637\u0627\u0642 \u0648\u0627\u0633\u0639. \u062a\u0633\u0627\u0639\u062f \u0647\u0630\u0647 \u0627\u0644\u0645\u064a\u0632\u0629 \u0641\u064a \u0645\u0646\u0639 \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u063a\u064a\u0631 \u0627\u0644\u0645\u0631\u063a\u0648\u0628 \u0641\u064a\u0647\u0627\u060c \u0648\u0647\u062c\u0645\u0627\u062a \u0627\u0644\u0631\u0648\u0628\u0648\u062a\u0627\u062a\u060c \u0648\u0627\u0644\u0648\u0635\u0648\u0644 \u063a\u064a\u0631 \u0627\u0644\u0645\u0635\u0631\u062d \u0628\u0647\u060c \u0645\u0645\u0627 \u064a\u0636\u0645\u0646 \u062a\u062c\u0631\u0628\u0629 \u0645\u0633\u062a\u062e\u062f\u0645 \u0623\u0643\u062b\u0631 \u0623\u0645\u0627\u0646\u064b\u0627."],"LoginPress integrates with the most popular WordPress plugins to enhance your login experience. Our Social Login, CAPTCHA and Limit Login Attempts features among others are easily integrated into these platforms, helping you streamline user access and enhance security.":["\u064a\u062a\u0643\u0627\u0645\u0644 LoginPress \u0645\u0639 \u0623\u0634\u0647\u0631 \u0625\u0636\u0627\u0641\u0627\u062a WordPress \u0644\u062a\u0639\u0632\u064a\u0632 \u062a\u062c\u0631\u0628\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0643. \u062a\u062a\u0645 \u062f\u0645\u062c \u0645\u064a\u0632\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u060c \u0648CAPTCHA\u060c \u0648\u062a\u062d\u062f\u064a\u062f \u0645\u062d\u0627\u0648\u0644\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0628\u0633\u0647\u0648\u0644\u0629 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0645\u0646\u0635\u0627\u062a\u060c \u0645\u0645\u0627 \u064a\u0633\u0627\u0639\u062f\u0643 \u0639\u0644\u0649 \u062a\u0628\u0633\u064a\u0637 \u0648\u0635\u0648\u0644 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0623\u0645\u0627\u0646."],"WooCommerce":["\u0648\u0648\u0643\u0648\u0645\u0631\u0633"],"Quick, secure logins for your WooCommerce store.":["\u062a\u0633\u062c\u064a\u0644 \u062f\u062e\u0648\u0644 \u0633\u0631\u064a\u0639 \u0648\u0622\u0645\u0646 \u0644\u0645\u062a\u062c\u0631 \u0648\u0648\u0643\u0648\u0645\u0631\u0633 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643."],"Easy Digital Downloads":["\u062a\u0646\u0632\u064a\u0644\u0627\u062a \u0631\u0642\u0645\u064a\u0629 \u0633\u0647\u0644\u0629"],"Secure digital purchases with login enhancements.":["\u0639\u0645\u0644\u064a\u0627\u062a \u0634\u0631\u0627\u0621 \u0631\u0642\u0645\u064a\u0629 \u0622\u0645\u0646\u0629 \u0645\u0639 \u062a\u062d\u0633\u064a\u0646\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644."],"BuddyPress":["\u0628\u0627\u062f\u064a \u0628\u0631\u0633"],"Boost community logins with social and captcha support.":["\u062a\u0639\u0632\u064a\u0632 \u062a\u0633\u062c\u064a\u0644\u0627\u062a \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u064a\u0629 \u0628\u062f\u0639\u0645 \u0645\u0646 \u0627\u0644\u0634\u0628\u0643\u0627\u062a \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0648CAPTCHA."],"BuddyBoss":["\u0628\u0627\u062f\u0649 \u0628\u0648\u0633"],"Hassle-free login experience for your BuddyBoss community.":["\u062a\u062c\u0631\u0628\u0629 \u062a\u0633\u062c\u064a\u0644 \u062f\u062e\u0648\u0644 \u062e\u0627\u0644\u064a\u0629 \u0645\u0646 \u0627\u0644\u0645\u062a\u0627\u0639\u0628 \u0644\u0645\u062c\u062a\u0645\u0639 \u0628\u0627\u062f\u0649 \u0628\u0648\u0633 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643."],"LifterLMS":["\u0644\u064a\u0641\u062a\u064a\u0631 \u0625\u0644 \u0625\u0645 \u0625\u0633"],"Let students log in easily and securely.":["\u062f\u0639 \u0627\u0644\u0637\u0644\u0627\u0628 \u064a\u0633\u062c\u0644\u0648\u0646 \u0627\u0644\u062f\u062e\u0648\u0644 \u0628\u0633\u0647\u0648\u0644\u0629 \u0648\u0623\u0645\u0627\u0646."],"LearnDash":["\u0644\u064a\u0631\u0646 \u062f\u0627\u0634"],"Simplify learning access with our login tools.":["\u0628\u0633\u0637 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0627\u0644\u062a\u0639\u0644\u0645 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0646\u0627."],"Upgrade Now":["\u062a\u0631\u0642\u064a\u0629 \u0627\u0644\u0622\u0646"],"Settings":["\u0627\u0644\u0625\u0639\u062f\u0627\u062f\u0627\u062a"],"Login Page Settings":["\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0635\u0641\u062d\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"How To Use LoginPress With Google reCaptcha V2":["\u0643\u064a\u0641\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 LoginPress \u0645\u0639 Google reCaptcha V2"],"How Auto Login Works":["\u0643\u064a\u0641\u064a\u0629 \u0639\u0645\u0644 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a"],"How Social Logins Works":["\u0643\u064a\u0641\u064a\u0629 \u0639\u0645\u0644 \u062a\u0633\u062c\u064a\u0644\u0627\u062a \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629"],"How Hide Login Works":["\u0643\u064a\u0641 \u064a\u0639\u0645\u0644 \u0625\u062e\u0641\u0627\u0621 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"How Limit Login Login Attempts Works":["\u0643\u064a\u0641 \u064a\u0639\u0645\u0644 \u062a\u062d\u062f\u064a\u062f \u0639\u062f\u062f \u0645\u062d\u0627\u0648\u0644\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"How Login Redirects Works":["\u0643\u064a\u0641 \u064a\u0639\u0645\u0644 \u0625\u0639\u0627\u062f\u0629 \u062a\u0648\u062c\u064a\u0647 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"],"Upgrade to Pro for More Features":["\u062a\u0631\u0642\u064a\u0629 \u0625\u0644\u0649 \u0627\u0644\u0646\u0633\u062e\u0629 \u0627\u0644\u0627\u062d\u062a\u0631\u0627\u0641\u064a\u0629 \u0644\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u064a\u0632\u0627\u062a"],"Get access to all premium features by upgrading to LoginPress Pro.":["\u0627\u062d\u0635\u0644 \u0639\u0644\u0649 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u064a\u0632\u0627\u062a \u0627\u0644\u0645\u0645\u064a\u0632\u0629 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0627\u0644\u062a\u0631\u0642\u064a\u0629 \u0625\u0644\u0649 LoginPress Pro."],"Video:":["\u0641\u064a\u062f\u064a\u0648:"],"Coming soon":["\u0642\u0631\u064a\u0628\u0627\u064b"],"No promotion available for this tab.":["\u0644\u062